# ============================================================
# KRATOS BASQUETE URBANO — Variáveis de Ambiente
# ============================================================
# Copie este arquivo: cp .env.example .env
# NUNCA commite o .env real no Git.
# ============================================================

# ── Ambiente ─────────────────────────────────────────────────
NODE_ENV=development

# ── Banco: kratos_core ───────────────────────────────────────
DB_KRATOS_USER=kratos_admin
DB_KRATOS_PASS=kratos_secret_change_me
DB_KRATOS_HOST=db_kratos
DB_KRATOS_PORT=5432
DB_KRATOS_NAME=kratos_core

# ── Banco: pmpa_govtech ──────────────────────────────────────
DB_PMPA_USER=pmpa_admin
DB_PMPA_PASS=pmpa_secret_change_me
DB_PMPA_HOST=db_pmpa
DB_PMPA_PORT=5432
DB_PMPA_NAME=pmpa_govtech

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT (Backend Kratos) ─────────────────────────────────────
JWT_SECRET=TROQUE_POR_STRING_ALEATORIA_LONGA_256bits
JWT_EXPIRES_IN=7d

# ── Comunicação interna Kratos ↔ PMPA ────────────────────────
KRATOS_INTERNAL_SECRET=TROQUE_POR_SEGREDO_INTERNO

# ── Mapbox (Frontend Mobile) ─────────────────────────────────
MAPBOX_TOKEN=pk.TROQUE_PELO_SEU_TOKEN_MAPBOX

# ── Upload de Fotos (Zeladoria) ──────────────────────────────
S3_BUCKET=kratos-zeladoria-photos
S3_REGION=sa-east-1
S3_ACCESS_KEY=TROQUE
S3_SECRET_KEY=TROQUE

# ── Push Notifications ───────────────────────────────────────
EXPO_ACCESS_TOKEN=TROQUE_PELO_SEU_TOKEN_EXPO
